; api-ms-win-crt-heap-l1-1-0.def
;
; UCRT apiset for heap functions. On real Windows this DLL
; just forwards to ucrtbase.dll. DuetOS's PE loader sees
; the apiset name directly in the PE's import table and
; resolves each function against kernel/subsystems/win32/
; stubs.cpp — the forwarder table lives in the kernel.
;
; Keep this list in sync with kStubsTable entries under the
; same DLL name in stubs.cpp. A mismatch surfaces at load
; time as UNRESOLVED <dll>!<func>.

LIBRARY api-ms-win-crt-heap-l1-1-0.dll

EXPORTS
    malloc
    free
    calloc
    realloc
    _aligned_malloc
    _aligned_free
