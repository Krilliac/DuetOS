; userland/apps/hello_winapi/kernel32.def
;
; Minimal .def file used to build a kernel32.lib import library
; (via llvm-dlltool). The resulting .lib lets lld-link satisfy
; __imp_ExitProcess without needing the real kernel32.dll or
; the Windows SDK. The kernel32.dll reference in the produced
; PE is a runtime concern — resolved by the CustomOS PE loader
; against its internal stub table.

LIBRARY kernel32.dll

; v0 Win32 surface CustomOS's kernel32 stub page resolves.
; Every name listed here must have a matching entry in
; kernel/subsystems/win32/stubs.cpp:kStubsTable. Keep the
; two lists in sync or the import resolver will reject the
; executable at load time with UNRESOLVED <dll>!<func>.
EXPORTS
    ; Batch 1 — console I/O
    ExitProcess
    GetStdHandle
    WriteFile
    WriteConsoleA
    ; Batch 2 — process/thread lifecycle
    GetCurrentProcess
    GetCurrentThread
    GetCurrentProcessId
    GetCurrentThreadId
    TerminateProcess
    ; Batch 3 — last-error slot
    GetLastError
    SetLastError
    ; Batch 4 — critical sections (v0 no-ops)
    InitializeCriticalSection
    InitializeCriticalSectionEx
    InitializeCriticalSectionAndSpinCount
    EnterCriticalSection
    LeaveCriticalSection
    DeleteCriticalSection
    ; Batch 9 — process heap
    GetProcessHeap
    HeapAlloc
    HeapFree
    HeapCreate
    HeapDestroy
    HeapReAlloc
    HeapSize
    ; Batch 10 — event/wait/time/process safe-ignore shims
    CreateEventW
    SetEvent
    ResetEvent
    WaitForSingleObject
    WaitForSingleObjectEx
    InitializeSListHead
    GetSystemTimeAsFileTime
    OpenProcess
    GetExitCodeThread
    GenerateConsoleCtrlEvent
    ; Batch 11 — perf counter + tick + Rtl/Toolhelp stubs
    QueryPerformanceCounter
    QueryPerformanceFrequency
    GetTickCount
    GetTickCount64
    RtlCaptureStackBackTrace
    RtlCaptureContext
    RtlLookupFunctionEntry
    RtlVirtualUnwind
    CreateToolhelp32Snapshot
    Process32FirstW
    Process32NextW
    CreateRemoteThread
    ResumeThread
    GetExitCodeProcess
    ; Batch 22 — timer + voluntary yield
    Sleep
    SwitchToThread
    ; Batch 23 — command line + environment
    GetCommandLineW
    GetCommandLineA
    GetEnvironmentVariableW
    GetEnvironmentStringsW
    FreeEnvironmentStringsW
    ; Batch 24 — file I/O (real handle table)
    CreateFileW
    ReadFile
    CloseHandle
    SetFilePointerEx
    ; Batch 25 — file stat + module lookup
    GetFileSizeEx
    GetModuleHandleW
    LoadLibraryW
    GetProcAddress
    FreeLibrary
    ; Batch 26 — Win32 mutex (real waitqueue-backed)
    CreateMutexW
    ReleaseMutex
    ; Batch 27 — console APIs
    WriteConsoleW
    GetConsoleMode
    SetConsoleMode
    GetConsoleCP
    GetConsoleOutputCP
    SetConsoleCP
    SetConsoleOutputCP
    OutputDebugStringW
    ; Batch 28 — virtual memory
    VirtualAlloc
    VirtualFree
    VirtualProtect
    ; Batch 29 — wide-string helpers
    lstrlenW
    lstrcmpW
    lstrcpyW
