// DuetOS — native syscall name table.
//
// Single source of truth for the (number, "SYS_NAME") pairs the
// runtime needs for diagnostic logging and the inspect-syscalls
// scanner. The numbers MUST match the SyscallNumber enum in
// kernel/core/syscall.h — every row is enforced by a static_assert
// in syscall_names.h, so a drift here fails the build instead of
// silently mislabelling a site at runtime.
//
// Adding a new SYS_FOO = N: append `X(SYS_FOO, N)` here AND extend
// the enum in core/syscall.h. Order is by number, even when the
// enum entry is placed out of order for documentation reasons
// (SYS_GDI_BITBLT_DC = 113 lives at the bottom of the enum but
// goes in numerical order here).

X(SYS_EXIT, 0)
X(SYS_GETPID, 1)
X(SYS_WRITE, 2)
X(SYS_YIELD, 3)
X(SYS_STAT, 4)
X(SYS_READ, 5)
X(SYS_DROPCAPS, 6)
X(SYS_SPAWN, 7)
X(SYS_GETPROCID, 8)
X(SYS_GETLASTERROR, 9)
X(SYS_SETLASTERROR, 10)
X(SYS_HEAP_ALLOC, 11)
X(SYS_HEAP_FREE, 12)
X(SYS_PERF_COUNTER, 13)
X(SYS_HEAP_SIZE, 14)
X(SYS_HEAP_REALLOC, 15)
X(SYS_WIN32_MISS_LOG, 16)
X(SYS_GETTIME_FT, 17)
X(SYS_NOW_NS, 18)
X(SYS_SLEEP_MS, 19)
X(SYS_FILE_OPEN, 20)
X(SYS_FILE_READ, 21)
