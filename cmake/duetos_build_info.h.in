#pragma once

// GENERATED by CMake `configure_file` from
// cmake/duetos_build_info.h.in — do not edit; edit the template.
//
// Why a generated header instead of `-D` defines: the git subject /
// branch are free-form text. Passing them on the compiler command
// line means they transit `/bin/sh`, and a commit subject containing
// a shell metacharacter (`;`, backtick, `$`, `"`, …) breaks EVERY
// build preset with `/bin/sh: Unterminated quoted string`
// (regression observed 2026-05-15: a `;` in a commit subject).
// `configure_file` writes the values into THIS FILE — they never
// touch the command line or a shell again. The values are still
// pre-sanitised in CMakeLists.txt to be valid C string literals
// (backslash/quote/non-printable folded).

#define DUETOS_GIT_HASH "@_duetos_git_hash@"
#define DUETOS_GIT_SUBJECT "@_duetos_git_subject@"
#define DUETOS_GIT_BRANCH "@_duetos_git_branch@"
#define DUETOS_GIT_AUTHOR_DATE "@_duetos_git_author_date@"
#define DUETOS_BUILD_DATE "@_duetos_build_date@"
