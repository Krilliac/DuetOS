{
  // Visual Studio (full IDE) "Open Folder" debug targets for DuetOS.
  //
  // DuetOS is a freestanding x86_64 kernel — it is NOT MSVC-buildable.
  // Build stays in WSL (cmake --preset x86_64-debug). Visual Studio is
  // used purely as a remote source debugger that attaches to the
  // kernel's GDB stub exposed by QEMU on tcp:1234 (WSL2 forwards
  // localhost, so Windows VS can reach it).
  //
  // Prerequisites:
  //   * VS 2022 with "Linux and embedded development with C++".
  //   * Open this repo as a WSL folder (\\wsl.localhost\Ubuntu-24.04\
  //     home\natew\source\DuetOS) so VS uses the WSL /usr/bin/gdb.
  //   * A debug build present: cmake --preset x86_64-debug &&
  //     cmake --build build/x86_64-debug
  //
  // One-button flow (QEMU configs): copy the tasks.vs.json snippet
  // from the repo's IDE-debugging notes into .vs/tasks.vs.json (that
  // dir is per-user, git-ignored) so the preLaunch starter runs
  // automatically. Without it, first run
  // `tools/debug/vs-start-qemu.sh demo` in a WSL shell, then pick a
  // config below and hit F5 to attach.
  //
  // One-button flow (in-house VMM config): the VMM is a native
  // Windows process (WinHvPlatform), so its starter is a PowerShell
  // script, not the WSL bash one. Drop this into .vs/tasks.vs.json:
  //
  //   {
  //     "version": "0.2.1",
  //     "tasks": [
  //       {
  //         "taskLabel": "start-duetos-vmm",
  //         "appliesTo": "launch.vs.json",
  //         "type": "default",
  //         "command": "powershell.exe",
  //         "args": [
  //           "-ExecutionPolicy", "Bypass", "-File",
  //           "${workspaceRoot}\\tools\\vmm\\vs-start-vmm.ps1",
  //           "-BuildKernel"
  //         ]
  //       }
  //     ]
  //   }
  //
  // then add  "preLaunchTask": "start-duetos-vmm"  to the in-house
  // VMM config below. Without it, run
  // `tools\vmm\vs-start-vmm.ps1 -BuildKernel` in a PowerShell window
  // first, then F5 that config. The script builds the kernel (WSL),
  // builds the VMM (MSVC), launches it with --gdb, and returns once
  // the port is accepting so the attach is race-free.
  "version": "0.2.1",
  "defaults": {},
  "configurations": [
    {
      "type": "cppdbg",
      "name": "DuetOS: Attach (demo int3 — pauses at end of kernel_main)",
      "project": "CMakeLists.txt",
      "program": "${workspaceRoot}/build/x86_64-debug/kernel/duetos-kernel.elf",
      "cwd": "${workspaceRoot}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtConnect": true,
      "externalConsole": false,
      "setupCommands": [
        { "text": "set confirm off", "ignoreFailures": true },
        { "text": "set print pretty on", "ignoreFailures": true }
      ]
    },
    {
      "type": "cppdbg",
      "name": "DuetOS: Attach (live, normal boot)",
      "project": "CMakeLists.txt",
      "program": "${workspaceRoot}/build/x86_64-debug/kernel/duetos-kernel.elf",
      "cwd": "${workspaceRoot}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtConnect": false,
      "externalConsole": false,
      "setupCommands": [
        { "text": "set disable-randomization off", "ignoreFailures": true },
        { "text": "set print pretty on", "ignoreFailures": true },
        { "text": "set confirm off", "ignoreFailures": true }
      ]
    },
    {
      // Attach to the bespoke in-house VMM (tools/vmm) instead of
      // QEMU. Easiest: wire the start-duetos-vmm preLaunchTask
      // (see the header) so F5 builds + launches the VMM for you;
      // otherwise start it by hand first:
      //
      //   tools\vmm\vs-start-vmm.ps1 -BuildKernel      (recommended)
      //   - or -  duetos-vmm.exe --kernel <...>.elf --gdb 1234
      //
      // It stops before the first guest instruction (like QEMU -S),
      // so this config uses stopAtConnect:true — set kernel
      // breakpoints, then continue. The stub serves the amd64 core
      // register set + memory via the guest page tables, so normal
      // source-level stepping works against duetos-kernel.elf's
      // DWARF.
      //
      // miDebuggerPath: the VMM is a native Windows process, so its
      // gdb port is on Windows localhost. Use a Windows/MSYS2
      // gdb.exe (NOT the WSL /usr/bin/gdb — WSL2 cannot reach the
      // Windows host via "localhost"). Set the path below to your
      // gdb.exe; the placeholder will not resolve as-is.
      "type": "cppdbg",
      "name": "DuetOS: Attach (in-house VMM, tcp:1234)",
      "project": "CMakeLists.txt",
      "program": "${workspaceRoot}/build/x86_64-debug/kernel/duetos-kernel.elf",
      "cwd": "${workspaceRoot}",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb.exe",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtConnect": true,
      "externalConsole": false,
      "setupCommands": [
        { "text": "set confirm off", "ignoreFailures": true },
        { "text": "set print pretty on", "ignoreFailures": true }
      ]
    }
  ]
}
