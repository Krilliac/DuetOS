# ─────────────────────────────────────────────────────────────────────────────
#                            DuetOS .gitignore
#        Build artifacts, disk/kernel images, compiler debris,
#        IDE files, and other generated content stay out of git.
# ─────────────────────────────────────────────────────────────────────────────

##########################
# CMake / build output   #
##########################

# Anchored to repo root: the project's CMake build dir is /build/.
# Sub-paths like /tools/build/ are real source directories and
# must NOT be ignored. (Without the leading slash, gitignore
# matches `build/` at any level — which silently ignores Python
# helpers under tools/build/ and forced every existing script
# there to be `git add -f`'d. This anchored form is the correct
# fix.)
/build/
/build-*/
/tools/vmm/build/
out/
cmake-build-*/

CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile

##########################
# OS / kernel images      #
##########################

*.img
*.iso
*.bin
*.elf
*.efi
*.ko
*.raw
*.qcow2

##########################
# Object / intermediate   #
##########################

*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
userland/apps/**/*.exe
!userland/apps/windows_kill/windows-kill.exe
!userland/apps/unity_engine/unity_engine.exe
*.pdb
*.gch
*.pch
*.d
*.map

##########################
# QEMU / debug artifacts  #
##########################

qemu.log
*.core
*.dmp
*.crash

# Output of tools/qemu/run-fix-cycle.sh (gen-fix-patches.py
# writes candidate patches under DUETOS_FIX_OUT, default
# ./fix-patches/ at the repo root).
fix-patches/

##########################
# Logs / scratch          #
##########################

*.log
*.tmp
*.temp
*.bak
*.backup*
*~
*.swp
*.swo

##########################
# IDE / editor            #
##########################

.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

.idea/
*.iml
*.iws

##########################
# OS / FS junk            #
##########################

.DS_Store
Thumbs.db
Desktop.ini

##########################
# Env / credentials       #
##########################

*.env
*.env.*.local
credentials.json
*.key
*.pem
*.pfx
settings.local.ini

##########################
# Coverage / reports      #
##########################

coverage/
coverage.*
lcov-report/
*.gcov
*.gcno
*.gcda

##########################
# Language runtimes       #
##########################

# Rust
target/
target-host/
Cargo.lock
!/Cargo.lock

# Python scratch (in tools/, scripts/)
__pycache__/
*.pyc

# Node (in case we ever need it for docs tooling)
node_modules/

##########################
# Generated docs          #
##########################

docs/api/
docs/html/
docs/xml/
docs/output/
docs/.api_checksums
docs/.doc_checksums

##########################
# CTest artifacts         #
##########################

Testing/

##########################
# Local dev scripts       #
##########################

localdev.sh
localdev.bat
localdev.ps1

##########################
# Archives                #
##########################

*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# End of DuetOS .gitignore
/docs/example-boot-log-debug.txt

##########################
# Brainstorm / spec tools #
##########################

.superpowers/

##############################################
# Claude Code harness — agent worktrees etc. #
##############################################

# Worktree-isolated subagents live under .claude/worktrees/agent-*/
# (each is a full repo checkout). Never commit them into the parent
# repo — the agent commits live on their own pushed branches.
.claude/
